// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  roleId    String   @map("role_id")
  role      Role     @relation("UserRoles", fields: [roleId], references: [id])
  email     String   @unique
  password  String
  passcode  String?
  name      String
  avatar    String
  publicKey String   @unique @map("public_key")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  isBanned  Boolean  @default(false) @map("is_banned")
  isDeleted Boolean  @default(false) @map("is_deleted")

  ownedFiles       File[]         @relation("FileOwner")
  sentShares       Share[]        @relation("ShareSender")
  receivedShares   Share[]        @relation("ShareRecipient")
  fileActivities   FileActivity[] @relation("FileActivityUser")
  createdGroups    Group[]        @relation("GroupCreator")
  groupMemberships GroupMember[]
  anomalyAlerts    AnomalyAlert[]

  @@map("users")
}

model Role {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  users     User[]   @relation("UserRoles")

  @@map("roles")
}

model File {
  id                      String             @id @default(uuid())
  ownerId                 String             @map("owner_id")
  owner                   User               @relation("FileOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  filename                String
  filePath                String             @map("file_path")
  wrappedAesKey           String             @map("wrapped_aes_key")
  mimeType                String             @map("mime_type")
  size                    BigInt
  createdAt               DateTime           @default(now()) @map("created_at")
  updatedAt               DateTime           @updatedAt @map("updated_at")
  isDeleted               Boolean            @default(false) @map("is_deleted")
  enableBlockchainLogging Boolean            @default(true) @map("enable_blockchain_logging")
  classification          FileClassification @default(UNCLASSIFIED)
  contentFlag             ContentFlag        @default(SAFE) @map("content_flag")

  shares     Share[]        @relation("FileShares")
  activities FileActivity[] @relation("FileActivities")

  @@map("files")
}

model Share {
  id            String    @id @default(uuid())
  fileId        String    @map("file_id")
  file          File      @relation("FileShares", fields: [fileId], references: [id], onDelete: Restrict)
  senderId      String    @map("sender_id")
  sender        User      @relation("ShareSender", fields: [senderId], references: [id], onDelete: Restrict)
  recipientId   String    @map("recipient_id")
  recipient     User      @relation("ShareRecipient", fields: [recipientId], references: [id], onDelete: Restrict)
  wrappedAesKey String    @map("wrapped_aes_key")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@unique([fileId, recipientId])
  @@map("shares")
}

enum FileActivityAction {
  SHARE
  DOWNLOAD
  DELETE
  REVOKE_SHARE
  VIEW
  UPLOAD
}

enum FileClassification {
  UNCLASSIFIED
  PUBLIC
  INTERNAL
  CONFIDENTIAL
  RESTRICTED
}

enum ContentFlag {
  SAFE
  SENSITIVE
  FLAGGED
}

enum AlertLevel {
  WARNING
  ALERT
  CRITICAL
}

enum AlertType {
  STATISTICAL
  POLICY
}

model Group {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdById String   @map("created_by_id")
  createdBy   User     @relation("GroupCreator", fields: [createdById], references: [id])
  createdAt   DateTime @default(now()) @map("created_at")

  members GroupMember[]

  @@map("groups")
}

model GroupMember {
  groupId String @map("group_id")
  userId  String @map("user_id")
  group   Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([groupId, userId])
  @@map("group_members")
}

model AnomalyAlert {
  id          String     @id @default(uuid())
  userId      String     @map("user_id")
  user        User       @relation(fields: [userId], references: [id])
  level       AlertLevel
  type        AlertType
  description String
  metadata    Json       @default("{}")
  isResolved  Boolean    @default(false) @map("is_resolved")
  createdAt   DateTime   @default(now()) @map("created_at")

  @@map("anomaly_alerts")
}

model FileActivity {
  id               String             @id @default(uuid())
  userId           String             @map("user_id")
  user             User               @relation("FileActivityUser", fields: [userId], references: [id], onDelete: Restrict)
  fileId           String             @map("file_id")
  file             File               @relation("FileActivities", fields: [fileId], references: [id], onDelete: Restrict)
  action           FileActivityAction
  metadata         Json               @default("{}")
  ipAddress        String?            @map("ip_address")
  userAgent        String?            @map("user_agent")
  blockchainTxHash String?            @map("blockchain_tx_hash")
  createdAt        DateTime           @default(now()) @map("created_at")

  @@map("file_activities")
}
