// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String          @id @default(uuid()) @map("id") @db.Uuid
  roleId               String          @map("role_id") @db.Uuid
  walletAddress        String          @unique @map("wallet_address") @db.VarChar(42)
  username             String?         @map("username") @db.VarChar(100)
  email                String?         @unique @map("email") @db.VarChar(255)
  kmsKeyName           String?         @map("kms_key_name") @db.Text
  storageUsed          BigInt          @default(0) @map("storage_used")
  storageLimit         BigInt          @default(1073741824) @map("storage_limit")
  isActive             Boolean         @default(true) @map("is_active")
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  lastLoginAt          DateTime?       @map("last_login_at")
  // Relations
  role                 Role            @relation("UserRoles", fields: [roleId], references: [id])
  files                File[]          @relation("UserFiles")
  grantsGiven          AccessGrant[]   @relation("Grantor")
  grantsReceived       AccessGrant[]   @relation("Grantee")
  downloads            Download[]
  receiptsSent         Receipt[]       @relation("Sender")
  receiptsReceived     Receipt[]       @relation("Recipient")
  notifications        Notification[]  @relation("NotificationUser")
  notificationsRelated Notification[]  @relation("NotificationRelatedUser")
  auditLogs            AuditLog[]      @relation("AuditLogUser")
  auditLogsTarget      AuditLog[]      @relation("AuditLogTargetUser")
  sessions             UserSession[]
  settingsUpdated      SystemSetting[] @relation("UpdatedBy")

  @@map("users")
}

model Role {
  id        String   @id @default(uuid()) @map("id") @db.Uuid
  name      String   @unique @map("name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  users     User[]   @relation("UserRoles")

  @@map("roles")
}

model File {
  id                String             @id @default(uuid()) @map("id") @db.Uuid
  ownerId           String             @map("owner_id") @db.Uuid
  fileHash          String             @unique @map("file_hash") @db.VarChar(66)
  cid               String             @map("cid") @db.VarChar(100)
  fileName          String             @map("file_name") @db.VarChar(255)
  fileSize          BigInt             @map("file_size")
  fileType          String?            @map("file_type") @db.VarChar(100)
  encryptedKeyOwner String             @map("encrypted_key_owner") @db.Text
  kmsEncryptedKey   String?            @map("kms_encrypted_key") @db.Text
  uploadTimestamp   DateTime           @default(now()) @map("upload_timestamp")
  txHash            String?            @map("tx_hash") @db.VarChar(66)
  blockchainFileId  BigInt?            @map("blockchain_file_id")
  status            String             @default("active") @map("status") @db.VarChar(20)
  metadata          Json?              @map("metadata")
  // Relations
  owner             User               @relation("UserFiles", fields: [ownerId], references: [id])
  grants            AccessGrant[]
  downloads         Download[]
  receipts          Receipt[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  ipfsPins          IpfsPin[]
  sharesSummary     FileSharesSummary?

  @@map("files")
}

model AccessGrant {
  id                  String     @id @default(uuid()) @map("id") @db.Uuid
  fileId              String     @map("file_id") @db.Uuid
  grantorId           String     @map("grantor_id") @db.Uuid
  granteeId           String     @map("grantee_id") @db.Uuid
  encryptedKeyGrantee String     @map("encrypted_key_grantee") @db.Text
  grantMessage        Json       @map("grant_message")
  signature           String     @map("signature") @db.Text
  grantedAt           DateTime   @default(now()) @map("granted_at")
  expiresAt           DateTime?  @map("expires_at")
  status              String     @default("active") @map("status") @db.VarChar(20)
  revokedAt           DateTime?  @map("revoked_at")
  revokeReason        String?    @map("revoke_reason")
  revokeSignature     String?    @map("revoke_signature") @db.Text
  // Relations
  file                File       @relation(fields: [fileId], references: [id])
  grantor             User       @relation("Grantor", fields: [grantorId], references: [id])
  grantee             User       @relation("Grantee", fields: [granteeId], references: [id])
  downloads           Download[]
  receipts            Receipt[]

  @@unique([fileId, granteeId], name: "idx_unique_grant")
  @@map("access_grants")
}

model Download {
  id                 String       @id @default(uuid()) @map("id") @db.Uuid
  fileId             String       @map("file_id") @db.Uuid
  userId             String       @map("user_id") @db.Uuid
  accessGrantId      String?      @map("access_grant_id") @db.Uuid
  downloadTimestamp  DateTime     @default(now()) @map("download_timestamp")
  ipAddress          String?      @map("ip_address") @db.VarChar(45)
  userAgent          String?      @map("user_agent") @db.Text
  status             String       @default("success") @map("status") @db.VarChar(20)
  errorMessage       String?      @map("error_message")
  fileSizeDownloaded BigInt?      @map("file_size_downloaded")
  // Relations
  file               File         @relation(fields: [fileId], references: [id])
  user               User         @relation(fields: [userId], references: [id])
  accessGrant        AccessGrant? @relation(fields: [accessGrantId], references: [id])

  @@map("downloads")
}

model Receipt {
  id               String      @id @default(uuid()) @map("id") @db.Uuid
  fileId           String      @map("file_id") @db.Uuid
  senderId         String      @map("sender_id") @db.Uuid
  recipientId      String      @map("recipient_id") @db.Uuid
  accessGrantId    String      @map("access_grant_id") @db.Uuid
  receiptMessage   Json        @map("receipt_message")
  signature        String      @map("signature") @db.Text
  receivedAt       DateTime    @default(now()) @map("received_at")
  status           String      @default("confirmed") @map("status") @db.VarChar(20)
  blockchainTxHash String?     @map("blockchain_tx_hash") @db.VarChar(66)
  // Relations
  file             File        @relation(fields: [fileId], references: [id])
  sender           User        @relation("Sender", fields: [senderId], references: [id])
  recipient        User        @relation("Recipient", fields: [recipientId], references: [id])
  accessGrant      AccessGrant @relation(fields: [accessGrantId], references: [id])

  @@unique([fileId, recipientId], name: "idx_unique_receipt")
  @@map("receipts")
}

model Notification {
  id               String    @id @default(uuid()) @map("id") @db.Uuid
  userId           String    @map("user_id") @db.Uuid
  notificationType String    @map("notification_type") @db.VarChar(50)
  title            String    @map("title") @db.VarChar(255)
  message          String    @map("message") @db.Text
  relatedFileId    String?   @map("related_file_id") @db.Uuid
  relatedUserId    String?   @map("related_user_id") @db.Uuid
  metadata         Json?     @map("metadata")
  isRead           Boolean   @default(false) @map("is_read")
  sentViaEmail     Boolean   @default(false) @map("sent_via_email")
  createdAt        DateTime  @default(now()) @map("created_at")
  readAt           DateTime? @map("read_at")
  // Relations
  user             User      @relation("NotificationUser", fields: [userId], references: [id])
  relatedFile      File?     @relation(fields: [relatedFileId], references: [id])
  relatedUser      User?     @relation("NotificationRelatedUser", fields: [relatedUserId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id               String   @id @default(uuid()) @map("id") @db.Uuid
  eventType        String   @map("event_type") @db.VarChar(50)
  userId           String   @map("user_id") @db.Uuid
  fileId           String?  @map("file_id") @db.Uuid
  targetUserId     String?  @map("target_user_id") @db.Uuid
  eventData        Json     @map("event_data")
  signature        String?  @map("signature") @db.Text
  blockchainTxHash String?  @map("blockchain_tx_hash") @db.VarChar(66)
  ipAddress        String?  @map("ip_address") @db.VarChar(45)
  userAgent        String?  @map("user_agent") @db.Text
  timestamp        DateTime @default(now()) @map("timestamp")
  // Relations
  user             User     @relation("AuditLogUser", fields: [userId], references: [id])
  file             File?    @relation(fields: [fileId], references: [id])
  targetUser       User?    @relation("AuditLogTargetUser", fields: [targetUserId], references: [id])

  @@map("audit_logs")
}

model SystemSetting {
  id           String   @id @default(uuid()) @map("id") @db.Uuid
  settingKey   String   @unique @map("setting_key") @db.VarChar(100)
  settingValue Json     @map("setting_value")
  description  String?  @map("description")
  updatedAt    DateTime @default(now()) @map("updated_at")
  updatedById  String?  @map("updated_by_id") @db.Uuid
  // Relations
  updatedBy    User?    @relation("UpdatedBy", fields: [updatedById], references: [id])

  @@map("system_settings")
}

model BlockchainSync {
  id              String   @id @default(uuid()) @map("id") @db.Uuid
  txHash          String   @unique @map("tx_hash") @db.VarChar(66)
  blockNumber     BigInt?  @map("block_number")
  eventType       String?  @map("event_type") @db.VarChar(50)
  contractAddress String   @map("contract_address") @db.VarChar(42)
  eventData       Json?    @map("event_data")
  syncedAt        DateTime @default(now()) @map("synced_at")
  status          String   @default("confirmed") @map("status") @db.VarChar(20)

  @@map("blockchain_sync")
}

model IpfsPin {
  id         String    @id @default(uuid()) @map("id") @db.Uuid
  fileId     String    @map("file_id") @db.Uuid
  pinService String?   @map("pin_service") @db.VarChar(50)
  pinStatus  String    @default("pinned") @map("pin_status") @db.VarChar(20)
  pinSize    BigInt?   @map("pin_size")
  pinnedAt   DateTime  @default(now()) @map("pinned_at")
  unpinnedAt DateTime? @map("unpinned_at")
  metadata   Json?     @map("metadata")
  // Relations
  file       File      @relation(fields: [fileId], references: [id])

  @@map("ipfs_pins")
}

model UserSession {
  id             String   @id @default(uuid()) @map("id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  sessionToken   String   @unique @map("session_token") @db.VarChar(255)
  walletAddress  String   @map("wallet_address") @db.VarChar(42)
  ipAddress      String?  @map("ip_address") @db.VarChar(45)
  userAgent      String?  @map("user_agent") @db.Text
  createdAt      DateTime @default(now()) @map("created_at")
  expiresAt      DateTime @map("expires_at")
  lastActivityAt DateTime @default(now()) @map("last_activity_at")
  isActive       Boolean  @default(true) @map("is_active")
  // Relations
  user           User     @relation(fields: [userId], references: [id])

  @@map("user_sessions")
}

model FileSharesSummary {
  fileId           String    @id @map("file_id") @db.Uuid
  totalShares      Int       @default(0) @map("total_shares")
  activeShares     Int       @default(0) @map("active_shares")
  revokedShares    Int       @default(0) @map("revoked_shares")
  totalDownloads   Int       @default(0) @map("total_downloads")
  totalReceipts    Int       @default(0) @map("total_receipts")
  lastSharedAt     DateTime? @map("last_shared_at")
  lastDownloadedAt DateTime? @map("last_downloaded_at")
  updatedAt        DateTime  @default(now()) @map("updated_at")
  // Relations
  file             File      @relation(fields: [fileId], references: [id])

  @@map("file_shares_summary")
}
